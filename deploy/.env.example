# Production .env template — bootstrap.sh copies this to /srv/forsure-be/.env
# and replaces __DATABASE_URL__. Fill in everything else before starting the
# service. Mirrors the schema in src/config/env.schema.ts.

# --- Runtime ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
APP_PUBLIC_URL=https://api.forsure.fyi

# --- Database (auto-injected by bootstrap.sh) ---
DATABASE_URL=__DATABASE_URL__

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Auth ---
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- CORS ---
# Mobile uses bearer auth (no cookies → CORS not strictly required for the app),
# but the marketing site / future web client need to be listed here.
CORS_ORIGINS=https://forsure.fyi,https://www.forsure.fyi

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@forsure.fyi
RESEND_FROM_NAME=forsure

# --- Storage (Cloudflare R2) ---
STORAGE_DRIVER=s3
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://pub-<hash>.r2.dev

# --- Places (Google Places New) ---
GOOGLE_PLACES_API_KEY=

# --- Push notifications (Expo) ---
# Optional. Higher rate limits + receipt fetching. Get from:
#   https://expo.dev/accounts/<your-account>/settings/access-tokens
EXPO_ACCESS_TOKEN=

# --- Error reporting (Sentry) ---
# Optional. When set, instrument.ts initializes the SDK; otherwise no-op.
SENTRY_DSN=
