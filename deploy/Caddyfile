{{DOMAIN}} {
	encode gzip zstd

	# Forwards client IP / scheme to the Node app via standard
	# X-Forwarded-* headers. Required for the app's `trust proxy`.
	reverse_proxy 127.0.0.1:3000 {
		header_up X-Real-IP {remote_host}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 7
		}
		format json
	}
}
