<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{{title}}</title>
  </head>
  <body style="margin:0;padding:0;background:#fafafa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#111;">
    {{#if preheader}}
      <span style="display:none;visibility:hidden;opacity:0;color:transparent;height:0;width:0;overflow:hidden;">{{preheader}}</span>
    {{/if}}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fafafa;padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:480px;background:#fff;border-radius:12px;">
            <tr>
              <td style="padding:32px;">
                <div style="font-size:20px;font-weight:700;color:#111;margin-bottom:24px;">forsure</div>
                {{> @partial-block }}
              </td>
            </tr>
          </table>
          <div style="max-width:480px;margin-top:16px;font-size:12px;color:#999;text-align:center;">
            forsure · the hangout app
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
