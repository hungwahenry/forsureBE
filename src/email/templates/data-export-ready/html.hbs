{{#> _layout title="Your data export is ready"}}
  <h1 style="font-size:18px;margin:0 0 12px;color:#111;">Your data is ready</h1>
  <p style="margin:0 0 16px;color:#555;line-height:1.5;">
    The export of your forsure account is ready to download. The link below works once and expires in {{ttlHours}} hours.
  </p>
  <div style="margin:16px 0 24px;">
    <a
      href="{{downloadUrl}}"
      style="display:inline-block;background:#111;color:#fff;text-decoration:none;padding:12px 20px;border-radius:8px;font-weight:600;"
    >Download my data</a>
  </div>
  <p style="margin:0 0 0;font-size:13px;color:#888;line-height:1.5;">
    If you didn't request this, ignore this email and consider changing your sign-in habits — someone may have your email open.
  </p>
{{/_layout}}
