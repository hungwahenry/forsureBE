generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ----- Auth -----

model User {
  id                    String     @id // usr_...
  email                 String     @unique
  emailVerifiedAt       DateTime?  @db.Timestamptz(3)
  status                UserStatus @default(ACTIVE)
  onboardingCompletedAt DateTime?  @db.Timestamptz(3)
  lastLoginAt           DateTime?  @db.Timestamptz(3)
  createdAt             DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime   @updatedAt @db.Timestamptz(3)

  profile                Profile?
  emailVerifications     EmailVerification[]
  refreshTokens          RefreshToken[]
  activities             Activity[]
  activityParticipations ActivityParticipant[]
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model EmailVerification {
  id         String    @id // evf_...
  email      String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  ipAddress  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([email, consumedAt])
}

model RefreshToken {
  id         String    @id // rt_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime  @db.Timestamptz(3)
  revokedAt  DateTime? @db.Timestamptz(3)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, revokedAt])
}

// ----- Profile -----

model Profile {
  id          String   @id // prf_...
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username    String   @unique
  displayName String
  dateOfBirth DateTime @db.Timestamptz(3)
  gender      Gender
  avatarKey   String
  locationLat Float
  locationLng Float
  // PostGIS geography point — generated from locationLat/locationLng. Read via raw SQL only.
  locationPoint Unsupported("geography(Point, 4326)")?
  placeName   String
  // Maintained by Postgres triggers — never write directly from app code.
  activitiesHostedCount Int @default(0)
  activitiesJoinedCount Int @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

// ----- Activities -----

model Activity {
  id               String                   @id // act_...
  authorUserId     String
  author           User                     @relation(fields: [authorUserId], references: [id], onDelete: Cascade)
  emoji            String
  title            String
  startsAt         DateTime                 @db.Timestamptz(3)
  placeName        String
  placeLat         Float
  placeLng         Float
  // PostGIS geography point — generated from placeLat/placeLng. Read via raw SQL only.
  placePoint       Unsupported("geography(Point, 4326)")?
  capacity         Int
  // Maintained by a Postgres trigger on ActivityParticipant — never write directly.
  participantCount Int                      @default(0)
  genderPreference ActivityGenderPreference
  status           ActivityStatus           @default(OPEN)
  createdAt        DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime                 @updatedAt @db.Timestamptz(3)

  participants ActivityParticipant[]

  @@index([startsAt])
  @@index([status, startsAt])
  @@index([authorUserId, createdAt])
}

enum ActivityStatus {
  OPEN
  FULL
  CANCELLED
  DONE
}

enum ActivityGenderPreference {
  ALL
  MALE
  FEMALE
}

model ActivityParticipant {
  id         String   @id // ap_...
  activityId String
  userId     String
  joinedAt   DateTime @default(now()) @db.Timestamptz(3)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId, joinedAt])
  @@index([activityId])
}
