generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ----- Auth -----

model User {
  id                    String     @id // usr_...
  email                 String     @unique
  emailVerifiedAt       DateTime?  @db.Timestamptz(3)
  status                UserStatus @default(ACTIVE)
  onboardingCompletedAt DateTime?  @db.Timestamptz(3)
  lastLoginAt           DateTime?  @db.Timestamptz(3)
  createdAt             DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime   @updatedAt @db.Timestamptz(3)

  profile                 Profile?
  emailVerifications      EmailVerification[]
  refreshTokens           RefreshToken[]
  activityParticipations  ActivityParticipant[]
  chatMessages            ChatMessage[]
  reportsFiled            Report[]
  activityPosts           ActivityPost[]
  notificationDevices     NotificationDevice[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  blocksMade              UserBlock[]              @relation("Blocker")
  blocksReceived          UserBlock[]              @relation("Blocked")
  stepUpChallenges        StepUpChallenge[]
  emailChangeChallenges   EmailChangeChallenge[]
  dataExportRequests      DataExportRequest[]
  easterEggDiscoveries    EasterEggDiscovery[]
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model EmailVerification {
  id         String    @id // evf_...
  email      String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  ipAddress  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([email, consumedAt])
}

model RefreshToken {
  id         String    @id // rt_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime  @db.Timestamptz(3)
  revokedAt  DateTime? @db.Timestamptz(3)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, revokedAt])
}

// ----- Profile -----

model Profile {
  id                       String                                 @id // prf_...
  userId                   String                                 @unique
  user                     User                                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  username                 String                                 @unique
  displayName              String
  bio                      String?
  dateOfBirth              DateTime                               @db.Timestamptz(3)
  gender                   Gender
  avatarKey                String
  locationLat              Float
  locationLng              Float
  locationPoint            Unsupported("geography(Point, 4326)")?
  placeName                String
  activitiesHostedCount    Int                                    @default(0)
  activitiesJoinedCount    Int                                    @default(0)
  activitiesCompletedCount Int                                    @default(0)
  messagesSentCount        Int                                    @default(0)
  memoriesPostedCount      Int                                    @default(0)
  photosSharedCount        Int                                    @default(0)
  createdAt                DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime                               @updatedAt @db.Timestamptz(3)
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

// ----- Activities -----

model Activity {
  id                        String                                 @id // act_...
  emoji                     String
  title                     String
  startsAt                  DateTime                               @db.Timestamptz(3)
  placeName                 String
  placeLat                  Float
  placeLng                  Float
  placePoint                Unsupported("geography(Point, 4326)")?
  capacity                  Int
  participantCount          Int                                    @default(0)
  messageCount              Int                                    @default(0)
  postCount                 Int                                    @default(0)
  genderPreference          ActivityGenderPreference
  status                    ActivityStatus                         @default(OPEN)
  memoriesShareablePublicly Boolean                                @default(false)
  pinnedMessageId           String?                                @unique
  createdAt                 DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt                 DateTime                               @updatedAt @db.Timestamptz(3)

  participants  ActivityParticipant[]
  chatMessages  ChatMessage[]
  pinnedMessage ChatMessage?          @relation("ActivityPinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)
  posts         ActivityPost[]

  @@index([startsAt])
  @@index([status, startsAt])
}

enum ActivityStatus {
  OPEN
  FULL
  CANCELLED
  DONE
}

enum ActivityGenderPreference {
  ALL
  MALE
  FEMALE
}

enum ActivityRole {
  HOST
  MEMBER
}

model ActivityParticipant {
  id         String       @id // ap_...
  activityId String
  userId     String
  role       ActivityRole @default(MEMBER)
  joinedAt   DateTime     @default(now()) @db.Timestamptz(3)
  lastReadAt DateTime?    @db.Timestamptz(3)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId, joinedAt])
  @@index([activityId])
  @@index([activityId, role])
}

// ----- Chat -----

enum ChatMessageKind {
  TEXT
  SYSTEM
}

model ChatMessage {
  id              String          @id // msg_...
  activityId      String
  senderUserId    String
  kind            ChatMessageKind @default(TEXT)
  body            String?
  imageKey        String?
  parentMessageId String?
  createdAt       DateTime        @default(now()) @db.Timestamptz(3)

  activity         Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  sender           User          @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  parent           ChatMessage?  @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies          ChatMessage[] @relation("MessageReplies")
  pinnedInActivity Activity?     @relation("ActivityPinnedMessage")

  @@index([activityId, createdAt])
}

// ----- Reports -----

enum ReportTargetType {
  USER
  ACTIVITY
  MESSAGE
  POST
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model ReportReason {
  id           String             @id // rsn_...
  code         String             @unique
  label        String
  description  String?
  applicableTo ReportTargetType[]
  isGeneral    Boolean            @default(false)
  active       Boolean            @default(true)
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now()) @db.Timestamptz(3)

  reports Report[]

  @@index([active, isGeneral])
}

model Report {
  id         String           @id // rep_...
  reporterId String
  targetType ReportTargetType
  targetId   String
  reasonId   String
  details    String?
  status     ReportStatus     @default(PENDING)
  createdAt  DateTime         @default(now()) @db.Timestamptz(3)
  reviewedAt DateTime?        @db.Timestamptz(3)
  reviewedBy String?

  reporter User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason   ReportReason @relation(fields: [reasonId], references: [id])

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status, createdAt])
}

// ----- Memories (Activity Posts) -----

enum PostVisibility {
  PARTICIPANTS
  PUBLIC
}

model ActivityPost {
  id         String         @id // pst_...
  activityId String
  authorId   String
  caption    String?
  visibility PostVisibility
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)

  activity Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author   User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  photos   ActivityPostPhoto[]

  @@unique([activityId, authorId])
  @@index([activityId, createdAt])
  @@index([visibility, createdAt])
  @@index([authorId, createdAt])
}

model ActivityPostPhoto {
  id        String   @id // pph_...
  postId    String
  imageKey  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  post ActivityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

// ----- Notifications -----

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum NotificationChannel {
  PUSH
  EMAIL
}

model NotificationDevice {
  id         String         @id // ndv_...
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Globally unique. If a different user signs in on this device, upsert reassigns userId.
  token      String         @unique
  platform   DevicePlatform
  lastSeenAt DateTime       @default(now()) @db.Timestamptz(3)
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)

  @@index([userId])
}

model UserBlock {
  id        String   @id // ublk_...
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model DataExportRequest {
  id            String    @id // exp_...
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// PENDING | COMPLETED | FAILED — string so adding states is migration-free.
  status        String    @default("PENDING")
  storageKey    String?
  downloadToken String?   @unique
  expiresAt     DateTime? @db.Timestamptz(3)
  consumedAt    DateTime? @db.Timestamptz(3)
  completedAt   DateTime? @db.Timestamptz(3)
  failedAt      DateTime? @db.Timestamptz(3)
  errorMessage  String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, createdAt])
}

model EasterEggDiscovery {
  id           String   @id // egd_...
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Identifier for the egg (e.g. 'credits'). String so adding eggs is migration-free.
  eggCode      String
  discoveredAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([userId, eggCode])
  @@index([eggCode, discoveredAt])
}

model EmailChangeChallenge {
  id         String    @id // ech_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail   String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, consumedAt])
}

model StepUpChallenge {
  id         String    @id // sup_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, action, consumedAt])
}

model Notification {
  id        String    @id // ntn_...
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventCode String
  title     String
  body      String
  data      Json
  groupKey  String?
  readAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@unique([userId, groupKey])
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NotificationPreference {
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventCode String
  channel   NotificationChannel
  enabled   Boolean
  createdAt DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @db.Timestamptz(3)

  @@id([userId, eventCode, channel])
  @@index([userId])
}
