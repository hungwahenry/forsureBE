generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ----- Auth -----

model User {
  id                    String     @id // usr_...
  email                 String     @unique
  emailVerifiedAt       DateTime?  @db.Timestamptz(3)
  status                UserStatus @default(ACTIVE)
  role                  UserRole   @default(USER)
  onboardingCompletedAt DateTime?  @db.Timestamptz(3)
  lastLoginAt           DateTime?  @db.Timestamptz(3)
  createdAt             DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime   @updatedAt @db.Timestamptz(3)

  /// Populated when status = SUSPENDED. Null suspendedUntil means indefinite.
  suspendedAt     DateTime? @db.Timestamptz(3)
  suspendedUntil  DateTime? @db.Timestamptz(3)
  suspendedReason String?
  suspendedById   String?
  suspendedBy     User?     @relation("UserSuspensions", fields: [suspendedById], references: [id], onDelete: SetNull)

  profile                 Profile?
  emailVerifications      EmailVerification[]
  refreshTokens           RefreshToken[]
  activityParticipations  ActivityParticipant[]
  chatMessages            ChatMessage[]
  reportsFiled            Report[]
  activityPosts           ActivityPost[]
  notificationDevices     NotificationDevice[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  blocksMade              UserBlock[]              @relation("Blocker")
  blocksReceived          UserBlock[]              @relation("Blocked")
  stepUpChallenges        StepUpChallenge[]
  emailChangeChallenges   EmailChangeChallenge[]
  dataExportRequests      DataExportRequest[]
  easterEggDiscoveries    EasterEggDiscovery[]

  // ----- Admin / moderation reverse relations -----
  suspensionsIssued    User[]          @relation("UserSuspensions")
  adminAuditLogs       AdminAuditLog[] @relation("AdminAuditLogs")
  chatMessagesDeleted  ChatMessage[]   @relation("ChatMessageDeletedBy")
  activityPostsDeleted ActivityPost[]  @relation("ActivityPostDeletedBy")
  activitiesDeleted    Activity[]      @relation("ActivityDeletedBy")
  featureFlagsUpdated  FeatureFlag[]   @relation("FeatureFlagUpdatedBy")

  // ----- Business reverse relations -----
  businessMemberships   BusinessMember[]
  businessSuspensions   Business[]             @relation("BusinessSuspendedBy")
  venueSuggestionEvents VenueSuggestionEvent[]

  // ----- Admin pages reverse relations -----
  adminPagesCreated AdminPage[] @relation("AdminPageCreator")
  adminPagesUpdated AdminPage[] @relation("AdminPageEditor")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model EmailVerification {
  id         String    @id // evf_...
  email      String
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  ipAddress  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([email, consumedAt])
}

model RefreshToken {
  id         String    @id // rt_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  familyId   String
  expiresAt  DateTime  @db.Timestamptz(3)
  revokedAt  DateTime? @db.Timestamptz(3)
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, revokedAt])
  @@index([familyId])
}

// ----- Profile -----

model Profile {
  id                       String                                 @id // prf_...
  userId                   String                                 @unique
  user                     User                                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  username                 String                                 @unique
  displayName              String
  bio                      String?
  dateOfBirth              DateTime                               @db.Timestamptz(3)
  gender                   Gender
  avatarKey                String
  locationLat              Float
  locationLng              Float
  locationPoint            Unsupported("geography(Point, 4326)")?
  placeName                String
  activitiesHostedCount    Int                                    @default(0)
  activitiesJoinedCount    Int                                    @default(0)
  activitiesCompletedCount Int                                    @default(0)
  messagesSentCount        Int                                    @default(0)
  memoriesPostedCount      Int                                    @default(0)
  photosSharedCount        Int                                    @default(0)
  createdAt                DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime                               @updatedAt @db.Timestamptz(3)
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

// ----- Activities -----

model Activity {
  id                        String                                 @id // act_...
  emoji                     String
  title                     String
  startsAt                  DateTime                               @db.Timestamptz(3)
  placeName                 String
  placeLat                  Float
  placeLng                  Float
  placePoint                Unsupported("geography(Point, 4326)")?
  capacity                  Int
  participantCount          Int                                    @default(0)
  messageCount              Int                                    @default(0)
  postCount                 Int                                    @default(0)
  genderPreference          ActivityGenderPreference
  status                    ActivityStatus                         @default(OPEN)
  memoriesShareablePublicly Boolean                                @default(false)
  pinnedMessageId           String?                                @unique
  createdAt                 DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt                 DateTime                               @updatedAt @db.Timestamptz(3)

  /// Admin soft-delete (takedown). Distinct from user-initiated CANCELLED status.
  deletedAt     DateTime? @db.Timestamptz(3)
  deletedById   String?
  deletedBy     User?     @relation("ActivityDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedReason String?

  /// Set when the host picked a sponsored BusinessVenue in the place picker.
  /// Drives D3 billing (CONFIRMED event on creation) and downstream venue analytics.
  businessVenueId String?
  businessVenue   BusinessVenue? @relation(fields: [businessVenueId], references: [id], onDelete: SetNull)

  participants          ActivityParticipant[]
  chatMessages          ChatMessage[]
  pinnedMessage         ChatMessage?           @relation("ActivityPinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)
  posts                 ActivityPost[]
  venueSuggestionEvents VenueSuggestionEvent[]
  boosts                ActivityBoost[]

  @@index([startsAt])
  @@index([status, startsAt])
  @@index([businessVenueId])
}

enum ActivityStatus {
  OPEN
  FULL
  CANCELLED
  DONE
}

enum ActivityGenderPreference {
  ALL
  MALE
  FEMALE
}

enum ActivityRole {
  HOST
  MEMBER
}

model ActivityParticipant {
  id         String       @id // ap_...
  activityId String
  userId     String
  role       ActivityRole @default(MEMBER)
  joinedAt   DateTime     @default(now()) @db.Timestamptz(3)
  lastReadAt DateTime?    @db.Timestamptz(3)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId, joinedAt])
  @@index([activityId])
  @@index([activityId, role])
}

// ----- Chat -----

enum ChatMessageKind {
  TEXT
  SYSTEM
}

model ChatMessage {
  id              String          @id // msg_...
  activityId      String
  senderUserId    String
  kind            ChatMessageKind @default(TEXT)
  body            String?
  imageKey        String?
  parentMessageId String?
  createdAt       DateTime        @default(now()) @db.Timestamptz(3)

  /// Admin soft-delete (takedown). User-initiated deletes still hard-delete.
  deletedAt     DateTime? @db.Timestamptz(3)
  deletedById   String?
  deletedBy     User?     @relation("ChatMessageDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedReason String?

  activity         Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  sender           User          @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  parent           ChatMessage?  @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies          ChatMessage[] @relation("MessageReplies")
  pinnedInActivity Activity?     @relation("ActivityPinnedMessage")

  @@index([activityId, createdAt])
}

// ----- Reports -----

enum ReportTargetType {
  USER
  ACTIVITY
  MESSAGE
  POST
  BUSINESS_VENUE
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model ReportReason {
  id           String             @id // rsn_...
  code         String             @unique
  label        String
  description  String?
  applicableTo ReportTargetType[]
  isGeneral    Boolean            @default(false)
  active       Boolean            @default(true)
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now()) @db.Timestamptz(3)

  reports Report[]

  @@index([active, isGeneral])
}

model Report {
  id         String           @id // rep_...
  reporterId String
  targetType ReportTargetType
  targetId   String
  reasonId   String
  details    String?
  status     ReportStatus     @default(PENDING)
  createdAt  DateTime         @default(now()) @db.Timestamptz(3)
  reviewedAt DateTime?        @db.Timestamptz(3)
  reviewedBy String?

  reporter User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason   ReportReason @relation(fields: [reasonId], references: [id])

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([status, createdAt])
}

// ----- Memories (Activity Posts) -----

enum PostVisibility {
  PARTICIPANTS
  PUBLIC
}

model ActivityPost {
  id         String         @id // pst_...
  activityId String
  authorId   String
  caption    String?
  visibility PostVisibility
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)

  /// Admin soft-delete (takedown). User-initiated deletes still hard-delete.
  deletedAt     DateTime? @db.Timestamptz(3)
  deletedById   String?
  deletedBy     User?     @relation("ActivityPostDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedReason String?

  activity Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  author   User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  photos   ActivityPostPhoto[]

  @@unique([activityId, authorId])
  @@index([activityId, createdAt])
  @@index([visibility, createdAt])
  @@index([authorId, createdAt])
}

model ActivityPostPhoto {
  id        String   @id // pph_...
  postId    String
  imageKey  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  post ActivityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
}

// ----- Notifications -----

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum NotificationChannel {
  PUSH
  EMAIL
}

model NotificationDevice {
  id         String         @id // ndv_...
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Globally unique. If a different user signs in on this device, upsert reassigns userId.
  token      String         @unique
  platform   DevicePlatform
  lastSeenAt DateTime       @default(now()) @db.Timestamptz(3)
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)

  @@index([userId])
}

model UserBlock {
  id        String   @id // ublk_...
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model DataExportRequest {
  id            String    @id // exp_...
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// PENDING | COMPLETED | FAILED — string so adding states is migration-free.
  status        String    @default("PENDING")
  storageKey    String?
  downloadToken String?   @unique
  expiresAt     DateTime? @db.Timestamptz(3)
  consumedAt    DateTime? @db.Timestamptz(3)
  completedAt   DateTime? @db.Timestamptz(3)
  failedAt      DateTime? @db.Timestamptz(3)
  errorMessage  String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, createdAt])
}

model EasterEggDiscovery {
  id           String   @id // egd_...
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Identifier for the egg (e.g. 'credits'). String so adding eggs is migration-free.
  eggCode      String
  discoveredAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([userId, eggCode])
  @@index([eggCode, discoveredAt])
}

model EmailChangeChallenge {
  id         String    @id // ech_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail   String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, consumedAt])
}

model StepUpChallenge {
  id         String    @id // sup_...
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamptz(3)
  consumedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([userId, action, consumedAt])
}

model Notification {
  id        String    @id // ntn_...
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventCode String
  title     String
  body      String
  data      Json
  groupKey  String?
  readAt    DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)

  @@unique([userId, groupKey])
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NotificationPreference {
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventCode String
  channel   NotificationChannel
  enabled   Boolean
  createdAt DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @db.Timestamptz(3)

  @@id([userId, eventCode, channel])
  @@index([userId])
}

// ----- Admin -----

model AdminAuditLog {
  id         String   @id // aal_...
  adminId    String
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Restrict)
  /// Action code, e.g. USER_SUSPENDED. String so adding actions is migration-free.
  action     String
  /// Target entity type, e.g. USER. Nullable for non-targeted actions (e.g. broadcast push).
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  reason     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model FeatureFlag {
  key           String   @id
  enabled       Boolean  @default(false)
  description   String?
  /// When true, the flag is returned by the public GET /feature-flags endpoint
  /// so mobile clients can mirror gating in their UI. Default true.
  clientExposed Boolean  @default(true)
  updatedById   String?
  updatedBy     User?    @relation("FeatureFlagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
}

model CronRunLog {
  id           String    @id // crl_...
  jobName      String
  startedAt    DateTime  @default(now()) @db.Timestamptz(3)
  finishedAt   DateTime? @db.Timestamptz(3)
  /// RUNNING | SUCCESS | FAILED — string so adding states is migration-free.
  status       String    @default("RUNNING")
  durationMs   Int?
  errorMessage String?
  errorStack   String?
  /// Optional job-specific result data (e.g. { dispatched: 42 }).
  result       Json?

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@index([status, startedAt])
}

// ----- Business -----

model Business {
  id                   String    @id // bus_...
  slug                 String    @unique
  name                 String
  logoKey              String?
  /// Banner image shown on the future consumer-facing business profile.
  coverPhotoKey        String?
  /// One-line description rendered on sponsored picker rows and business profiles. 280 chars max.
  shortDescription     String?
  /// Public-facing contact email/phone for admin and customer-support use.
  supportEmail         String?
  supportPhone         String?
  categoryId           String?
  category             BusinessCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  verifiedAt           DateTime? @db.Timestamptz(3)
  suspendedAt          DateTime? @db.Timestamptz(3)
  suspendedById        String?
  suspendedBy          User?     @relation("BusinessSuspendedBy", fields: [suspendedById], references: [id], onDelete: SetNull)
  suspendedReason      String?
  /// Set by the auto-pause cron when 3+ distinct users flag this business's venues in the last 30 days.
  /// Same gating semantics as `suspendedAt` — venues hidden from suggestions, boosts pulled from feed.
  /// Lifted manually by admin after review.
  autoPausedAt         DateTime? @db.Timestamptz(3)
  /// Stripe customer id for billing. Set after first successful checkout.
  stripeCustomerId     String?   @unique
  /// Stripe subscription id for the verified-business tier. Null when not subscribed.
  stripeSubscriptionId String?   @unique
  /// Latest Stripe subscription status (active, past_due, unpaid, canceled, etc.).
  /// Mirrored from `customer.subscription.updated` and `.deleted` webhooks.
  stripeSubscriptionStatus       String?
  /// When stripeSubscriptionStatus was last *changed* — i.e. transition time, not webhook receipt.
  stripeSubscriptionStatusAt     DateTime? @db.Timestamptz(3)
  createdAt            DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(3)

  members BusinessMember[]
  venues  BusinessVenue[]
  boosts  ActivityBoost[]

  @@index([categoryId])
}

model BusinessCategory {
  id          String  @id // bcg_...
  code        String  @unique
  label       String
  description String?
  /// Icon name from the mobile/web icon set. Optional — not rendered until icon mapping ships.
  iconName    String?
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  businesses Business[]

  @@index([active, sortOrder])
}

enum BusinessMemberRole {
  OWNER
  MANAGER
}

model BusinessMember {
  id         String             @id // bmm_...
  businessId String
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       BusinessMemberRole
  createdAt  DateTime           @default(now()) @db.Timestamptz(3)

  @@unique([businessId, userId])
  @@index([userId])
}

model BusinessVenue {
  id                   String                                 @id // bvn_...
  businessId           String
  business             Business                               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  placeName            String
  placeLat             Float
  placeLng             Float
  placePoint           Unsupported("geography(Point, 4326)")?
  googlePlaceId        String?
  /// Lowercase terms matched against the user's place-picker query to surface this venue.
  matchingKeywords     String[]
  /// Geographic eligibility radius in metres for being suggested to a nearby user.
  maxRadiusM           Int                                    @default(5000)
  isPaused             Boolean                                @default(false)
  /// Refilled at the start of each UTC day from dailyBudgetCents.
  dailyBudgetCents     Int                                    @default(0)
  dailyBudgetRemaining Int                                    @default(0)
  /// Direct contact for the venue (rendered on the future venue detail screen).
  phoneNumber          String?
  websiteUrl           String?
  /// Array of `{ day: 0-6, open: "HH:MM", close: "HH:MM" }`. Missing days = closed.
  /// Multiple entries per day allowed for split hours (lunch + dinner).
  openingHours         Json?
  createdAt            DateTime                               @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                               @updatedAt @db.Timestamptz(3)

  suggestionEvents VenueSuggestionEvent[]
  activities       Activity[]
  photos           BusinessVenuePhoto[]

  @@unique([businessId, googlePlaceId])
  @@index([businessId])
}

model BusinessVenuePhoto {
  id        String        @id // bvp_...
  venueId   String
  venue     BusinessVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  imageKey  String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)

  @@index([venueId, sortOrder])
}

model VenueSuggestionEvent {
  id                  String        @id // vse_...
  venueId             String
  venue               BusinessVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  userId              String
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// IMPRESSION | PICK | CONFIRMED — string so adding kinds is migration-free.
  kind                String
  activityId          String?
  activity            Activity?     @relation(fields: [activityId], references: [id], onDelete: SetNull)
  chargedCents        Int?
  /// Set by the rollover cron when this event's chargedCents was rolled into
  /// a Stripe invoice item against the business's active subscription.
  stripeInvoiceItemId String?
  settledAt           DateTime?     @db.Timestamptz(3)
  createdAt           DateTime      @default(now()) @db.Timestamptz(3)

  @@index([venueId, createdAt])
  @@index([userId, venueId, createdAt])
  @@index([settledAt])
}

model ActivityBoost {
  id                  String    @id // abt_...
  activityId          String
  activity            Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  /// Geographic eligibility radius in metres — users within this distance see the activity in their feed.
  radiusM             Int
  startsAt            DateTime  @db.Timestamptz(3)
  /// MIN(startsAt + 72h, activity.startsAt) — locked at creation time.
  endsAt              DateTime  @db.Timestamptz(3)
  /// 0 for a bundled-with-subscription boost, >0 for an overage that hit the Stripe invoice.
  chargedCents        Int       @default(0)
  isOverage           Boolean   @default(false)
  /// Set when chargedCents > 0 — references the Stripe invoice item attached to the customer's next invoice.
  stripeInvoiceItemId String?   @unique
  /// Host cancelled the activity, or the business explicitly stopped the boost early.
  cancelledAt         DateTime? @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(3)

  @@index([activityId, endsAt])
  @@index([businessId, createdAt])
  @@index([endsAt])
}

enum AdminPageStatus {
  DRAFT
  PUBLISHED
}

/// Admin-authored content pages (terms, privacy, FAQ, etc.) rendered on the public web at /p/{slug}.
model AdminPage {
  id          String          @id // pg_...
  slug        String          @unique
  title       String
  /// TipTap document model — source of truth for editing.
  bodyJson    Json
  /// Sanitized HTML generated from bodyJson at save time; what the public route renders.
  bodyHtml    String
  status      AdminPageStatus @default(DRAFT)
  publishedAt DateTime?       @db.Timestamptz(3)
  /// When true and status=PUBLISHED, the page is exposed in /pages/footer for the shared site footer.
  showInFooter Boolean        @default(false)
  /// Lower comes first when rendered in the footer. Ties broken by title.
  footerOrder  Int            @default(0)
  createdById String
  updatedById String
  createdBy   User            @relation("AdminPageCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User            @relation("AdminPageEditor", fields: [updatedById], references: [id], onDelete: Restrict)
  createdAt   DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(3)

  @@index([status, updatedAt])
  @@index([showInFooter, footerOrder])
}
