# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
APP_PUBLIC_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://USER@localhost:5432/forsure_dev?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-at-least-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# App-store review account: lets a reviewer sign in on this one email with
# REVIEW_ACCOUNT_CODE instead of the emailed OTP. Both must be set to enable;
# leave blank (or remove) to disable once review is done.
REVIEW_ACCOUNT_EMAIL=
REVIEW_ACCOUNT_CODE=

# --- CORS ---
# Mobile (Expo dev server) origins + the web panel domain in production.
# In prod: https://forsure.wtf
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3001

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@forsure.app
RESEND_FROM_NAME=forsure

# --- Contact form ---
# Cloudflare Turnstile secret. When unset, captcha verification is skipped.
TURNSTILE_SECRET_KEY=

# --- Storage ---
# Drivers: 'local' (writes to LOCAL_STORAGE_DIR, served via /static)
#          's3'    (any S3-compatible: R2, AWS, B2, Spaces, MinIO, ...)
STORAGE_DRIVER=local

# Local driver
LOCAL_STORAGE_DIR=./uploads
LOCAL_PUBLIC_URL=http://localhost:3000/static

# S3-compatible driver (required when STORAGE_DRIVER=s3)
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=forsure-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://pub-<hash>.r2.dev

# --- Places (Google Places New, Essentials tier) ---
GOOGLE_PLACES_API_KEY=AIza...

# --- Push notifications (Expo) ---
EXPO_ACCESS_TOKEN=

# --- Error reporting (Sentry) ---
SENTRY_DSN=

# --- Billing (Stripe) ---
# Backend-only — Stripe interactions happen server-side.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price id for the recurring 'verified business' subscription product.
STRIPE_PRICE_ID_VERIFIED_BUSINESS=price_...
# Where Stripe Checkout redirects after a session — the web panel's base URL.
STRIPE_RETURN_URL_BASE=http://localhost:3001
